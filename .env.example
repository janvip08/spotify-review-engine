# ---------------------------------------------------------------------------
# Spotify Review Discovery Engine — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env (no .example suffix) and fill in your values.
# The .env file is gitignored — never commit real credentials.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# YouTube Data API v3
# ---------------------------------------------------------------------------
# Get a free API key from: https://console.cloud.google.com/apis
# Steps:
#   1. Create a Google Cloud project (or use an existing one)
#   2. Enable "YouTube Data API v3" in the API library
#   3. Create credentials → API key
#   4. Paste the key below
#
# Free tier quota: 10,000 units/day (search=100 units, commentThreads=1 unit)
# This is more than enough for our fetch (~50 search + ~500 comment calls).

YOUTUBE_API_KEY=your_youtube_api_key_here

# ---------------------------------------------------------------------------
# Reddit API Credentials (LEGACY — not needed for manual curation)
# ---------------------------------------------------------------------------
# Reddit data is now collected via manual curation (ADR-011).
# These credentials are only needed if you re-enable automated fetching.
#
# Get these from: https://www.reddit.com/prefs/apps
# Create a "script" type app — no user login needed, read-only access.

# REDDIT_CLIENT_ID=your_client_id_here
# REDDIT_CLIENT_SECRET=your_client_secret_here
